model Stock {
  id            String   @id @default(uuid())
  companyId     String
  ownerId       String
  purchasePrice Float
  quantity      Int      @default(1)
  purchasedAt   DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@map("stocks")
  @@index([companyId])
  @@index([ownerId])
}
