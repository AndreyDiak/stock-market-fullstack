model News {
  id          String       @id @default(uuid())
  title       String
  body        String?
  impact      Float
  sentiment   Sentiment    @default(NEUTRAL)
  sector      MarketSector?
  companyId   String?
  publishedAt DateTime     @default(now())
  expiresAt   DateTime

  gameId      String?
  kind        String   @default("MARKET")
  payload     Json?

  company Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)
  game    Game?    @relation(fields: [gameId], references: [id], onDelete: Cascade)

  scheduledPriceImpacts ScheduledPriceImpact[]
  newsPressures         NewsPressure[]

  @@map("news")
  @@index([companyId])
  @@index([sector])
  @@index([expiresAt])
  @@index([gameId])
}
