model User {
  id          String  @id @default(uuid())
  email       String  @unique
  googleId    String? @unique
  yandexId    String? @unique
  displayName String
  avatarUrl   String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  lastLoginAt DateTime @default(now())

  games         Game[]
  refreshTokens RefreshToken[]

  @@map("users")
}
