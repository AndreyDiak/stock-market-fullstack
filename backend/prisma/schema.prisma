generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum MarketSector {
  HEALTHCARE // Icon heart
  TECHNOLOGY // Icon cpu
  FINANCE // Icon report-money
  AGRICULTURE // Icon leaf
  ENERGY // Icon bolt
}

enum Sentiment {
  POSITIVE
  NEGATIVE
  NEUTRAL
}

model RefreshToken {
  id     String @id @default(uuid())
  token  String @unique
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  expiresAt DateTime
  createdAt DateTime  @default(now())
  revokedAt DateTime?

  @@map("refresh_tokens")
}
